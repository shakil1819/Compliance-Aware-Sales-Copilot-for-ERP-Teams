# OpenAI API key - required for LLM Tier-2 classification and optional LLM formatting
# Without this, the system works fully on keyword classification + deterministic output
OPENAI_API_KEY=sk-...

# Set to "true" to enable LLM natural-language explanation around deterministic tool output
# Default: false (deterministic-only output, works without any API key)
USE_LLM_FORMATTING=false
